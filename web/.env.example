# Ollama runtime
OLLAMA_HOST=http://localhost:11434
GEMMA_MODEL=gemma4:e4b

# Vision: set to "true" on Windows / pre-Mac to return canned data
# instead of calling Gemma 4 vision (which requires Ollama).
# Leave unset on the Mac Mini to use the real model.
STUB_VISION=false

# Optional overrides
# HPE_DB_PATH=/abs/path/to/hospital.duckdb
# HPE_SEED_DIR=/abs/path/to/seed
